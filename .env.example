# ---------------------------------------------------------------------------
# PROJECT-RUN — Environment Variables
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to version control.
# ---------------------------------------------------------------------------

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# EAS / Expo
EXPO_PUBLIC_EAS_PROJECT_ID=YOUR_EAS_PROJECT_ID

# RevenueCat
EXPO_PUBLIC_REVENUECAT_IOS=YOUR_REVENUECAT_IOS_API_KEY
EXPO_PUBLIC_REVENUECAT_ANDROID=YOUR_REVENUECAT_ANDROID_API_KEY

# PostHog Analytics
EXPO_PUBLIC_POSTHOG_API_KEY=phc_YOUR_POSTHOG_KEY

# Supabase Edge Function Secrets (set via: supabase secrets set KEY=value)
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
# REVENUECAT_WEBHOOK_SECRET=YOUR_REVENUECAT_WEBHOOK_SECRET

# ---------------------------------------------------------------------------
# EAS Submit — iOS App Store (set as EAS secrets, NOT in .env)
# See: DEPLOYMENT.md for instructions on where to find each value.
# ---------------------------------------------------------------------------
# APPLE_ID=you@example.com
# ASC_APP_ID=1234567890
# APPLE_TEAM_ID=XXXXXXXXXX
